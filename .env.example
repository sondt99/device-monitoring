# Admin credentials (required on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-long-password

# Session cookie secret (required, at least 32 random characters)
COOKIE_SECRET=change-this-to-a-random-32-plus-character-secret

# Set to true only if serving over HTTPS (behind TLS terminator like nginx/Caddy)
SECURE_COOKIES=false

# Number of days to retain heartbeat records (default: 30)
BEAT_RETENTION_DAYS=30

# Enable the public status page (default: false)
ENABLE_STATUS_PAGE=false
